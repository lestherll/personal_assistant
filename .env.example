# Anthropic API key — required for the Anthropic provider
ANTHROPIC_API_KEY=

# PostgreSQL connection string — optional when AUTH_DISABLED=true, required otherwise.
# Run `uv run alembic upgrade head` after setting this to apply migrations.
#
# Format: postgresql+asyncpg://user:password@host:port/dbname
# For docker-compose: postgresql+asyncpg://postgres:postgres@db:5432/personal_assistant
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/personal_assistant

# Auth settings — generate SECRET_KEY with: openssl rand -hex 32
SECRET_KEY=change-me-in-production-32-plus-bytes
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
AUTH_DISABLED=false   # set true to skip auth entirely (dev/test only)
